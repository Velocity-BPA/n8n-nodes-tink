{
  "name": "n8n-nodes-tink",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for the Tink open banking platform providing 21 resources and 150+ operations for account aggregation, payments, identity verification, and financial insights. Includes PSD2-compliant AIS/PIS services and Tink Link integration.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-tink.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-tink#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-tink/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "tink",
    "open-banking",
    "psd2",
    "account-aggregation",
    "payment-initiation",
    "identity-verification",
    "financial-data",
    "banking-api",
    "ais",
    "pis",
    "fintech",
    "european-banking"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/TinkApi.credentials.js",
      "dist/credentials/TinkOAuth.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Tink/Tink.node.js",
      "dist/nodes/Tink/TinkTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.30.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "crypto-js": "^4.2.0",
    "qs": "^6.11.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
